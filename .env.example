# Supabase project reference ID (found in Project Settings > General)
VITE_SUPABASE_PROJECT_ID=your_project_id

# Supabase public anon key (found in Project Settings > API)
VITE_SUPABASE_ANON_KEY=your_anon_key

# Supabase Edge Function slug (the path segment after /functions/v1/)
VITE_SUPABASE_FUNCTION_SLUG=your_function_slug

# Public frontend URL used when generating shareable caregiver/family links
VITE_SITE_URL=https://your-deployment-url.example.com
